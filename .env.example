# GitHub OAuth — create at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Your GitHub username (gets admin privileges)
ADMIN_GITHUB_USERNAME=your_github_username

# Session secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me

# Database (Railway sets this automatically when you add PostgreSQL addon)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
